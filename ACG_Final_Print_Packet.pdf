(/**) Tj
T*
( * Generates a full mesh/grid of points representing the Bezier surface.) Tj
T*
( * Useful for rendering the surface in a 3D engine like Three.js.) Tj
T*
( * @param controlGrid - A 2D array [row][col] of 3D control points.) Tj
T*
( * @param resolution - How many segments to divide the surface into.) Tj
T*
( * @returns A 2D array of points representing the final evaluated surface.) Tj
T*
( */) Tj
T*
(export function generateSurfaceMesh\(controlGrid: Point3D[][], resolution: number\): Point3D[][]) Tj
T*
({) Tj
T*
(    const surfaceMesh: Point3D[][] = [];) Tj
T*
() Tj
T*
(    for \(let i = 0; i <= resolution; i++\) {) Tj
T*
(        const u = i / resolution;) Tj
T*
(        const row: Point3D[] = [];) Tj
T*
(        ) Tj
T*
(        for \(let j = 0; j <= resolution; j++\) {) Tj
T*
(            const v = j / resolution;) Tj
T*
(            row.push\(evaluateBezierSurface\(controlGrid, u, v\)\);) Tj
T*
(        }) Tj
T*
(        ) Tj
T*
(        surfaceMesh.push\(row\);) Tj
T*
(    }) Tj
T*
() Tj
T*
(    return surfaceMesh;) Tj
T*
(}) Tj
