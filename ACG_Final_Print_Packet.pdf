(    // Step 1: Reduce each row of the grid into a single point using parameter 'u') Tj
T*
(    for \(let i = 0; i < controlGrid.length; i++\) {) Tj
T*
(        const pointAtU = deCasteljau3D\(controlGrid[i], u\);) Tj
T*
(        uCurvePoints.push\(pointAtU\);) Tj
T*
(    }) Tj
T*
() Tj
T*
(    // Step 2: Reduce the resulting column of points into a final point using parameter 'v') Tj
