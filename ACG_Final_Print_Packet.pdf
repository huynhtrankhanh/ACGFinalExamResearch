(    # 1. Chord-length parameterization) Tj
T*
(    t_values = np.zeros\(m\)) Tj
T*
(    distances = np.linalg.norm\(np.diff\(data_points, axis=0\), axis=1\)) Tj
T*
(    cumulative_dist = np.insert\(np.cumsum\(distances\), 0, 0\)) Tj
T*
(    t_values = cumulative_dist / cumulative_dist[-1]) Tj
T*
(    ) Tj
T*
(    # 2. Build the Matrix M) Tj
T*
(    M = np.zeros\(\(m, n + 1\)\)) Tj
T*
(    for k in range\(m\):) Tj
T*
(        for i in range\(n + 1\):) Tj
T*
(            M[k, i] = bernstein_poly\(n, i, t_values[k]\)) Tj
T*
(            ) Tj
T*
(    # 3. Solve the Normal Equations: P = \(M^T * M\)^-1 * M^T * D) Tj
T*
(    # Note: np.linalg.lstsq does this efficiently and handles edge cases) Tj
T*
(    P, residuals, rank, s = np.linalg.lstsq\(M, data_points, rcond=None\)) Tj
T*
(    ) Tj
T*
(    # Ensure exact endpoint matching \(optional but highly recommended\)) Tj
T*
(    P[0] = data_points[0]) Tj
T*
(    P[-1] = data_points[-1]) Tj
T*
(    ) Tj
T*
(    return P) Tj
T*
() Tj
T*
(```) Tj
